<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="V18-create-sent-reminders" author="zahaand">
        <createTable tableName="sent_reminders">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="habit_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="sent_date" type="date">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamptz" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="sent_reminders" baseColumnNames="habit_id"
                                 constraintName="fk_sent_reminders_habit"
                                 referencedTableName="habits" referencedColumnNames="id"
                                 onDelete="CASCADE"/>

        <addForeignKeyConstraint baseTableName="sent_reminders" baseColumnNames="user_id"
                                 constraintName="fk_sent_reminders_user"
                                 referencedTableName="users" referencedColumnNames="id"
                                 onDelete="CASCADE"/>

        <addUniqueConstraint tableName="sent_reminders" columnNames="habit_id, sent_date"
                             constraintName="uq_sent_reminders_habit_date"/>

        <createIndex tableName="sent_reminders" indexName="idx_sent_reminders_habit_id">
            <column name="habit_id"/>
        </createIndex>

        <createIndex tableName="sent_reminders" indexName="idx_sent_reminders_user_id">
            <column name="user_id"/>
        </createIndex>

        <rollback>
            <dropAllForeignKeyConstraints baseTableName="sent_reminders"/>
            <dropTable tableName="sent_reminders"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
